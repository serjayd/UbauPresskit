<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    tools:context=".fragments.ContactFragment">

    <LinearLayout
        android:id="@+id/subscription_header"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:layout_marginBottom="32dp">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            style="@style/HeadingOne"
            android:text="@string/contact_title"
            android:layout_marginBottom="8dp"/>

        <TextView
            android:id="@+id/subscription_subtitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            style="@style/SpanTwo"
            android:text="@string/contact_subtitle" />
    </LinearLayout>

    <!--  Name  -->
    <LinearLayout
        android:id="@+id/contact_form_name"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:layout_marginBottom="16dp">

        <TextView
            android:id="@+id/name_label"
            style="@style/SpanThree"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="6dp"
            android:text="@string/name_form_label"
            android:textStyle="bold" />

        <EditText
            android:id="@+id/contact_name_input"
            style="@style/BodyTwo"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:autofillHints="@string/name_hint"
            android:background="@drawable/glass_card"
            android:hint="@string/name_hint"
            android:inputType="textPersonName"
            android:textColor="@color/text_primary"
            android:minHeight="48dp"
            android:paddingVertical="8dp"
            android:paddingHorizontal="16dp"
            android:textCursorDrawable="@null" />

        <TextView
            android:id="@+id/contact_name_error"
            style="@style/SpanThree"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:textColor="@color/destructive"
            android:textStyle="bold" />

    </LinearLayout>

    <!--  Email  -->
    <LinearLayout
        android:id="@+id/contact_form_email"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:layout_marginBottom="16dp">

        <TextView
            android:id="@+id/email_label"
            style="@style/SpanThree"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="6dp"
            android:text="@string/email_form_label"
            android:textStyle="bold" />

        <EditText
            android:id="@+id/contact_email_input"
            style="@style/BodyTwo"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:autofillHints="@string/name_hint"
            android:background="@drawable/glass_card"
            android:hint="@string/email_hint"
            android:inputType="textEmailAddress"
            android:textColor="@color/text_primary"
            android:minHeight="48dp"
            android:paddingVertical="8dp"
            android:paddingHorizontal="16dp"
            android:textCursorDrawable="@null" />

        <TextView
            android:id="@+id/contact_email_error"
            style="@style/SpanThree"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:textColor="@color/destructive"
            android:textStyle="bold" />

    </LinearLayout>

    <!--  Message  -->
    <LinearLayout
        android:id="@+id/contact_form_message"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:layout_marginBottom="16dp">

        <TextView
            android:id="@+id/message_label"
            style="@style/SpanThree"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="6dp"
            android:text="@string/message_form_label"
            android:textStyle="bold" />

        <EditText
            android:id="@+id/contact_message_input"
            style="@style/BodyTwo"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:autofillHints="@string/name_hint"
            android:background="@drawable/glass_card"
            android:hint="@string/message_hint"
            android:inputType="text"
            android:textColor="@color/text_primary"
            android:minHeight="128dp"
            android:gravity="top"
            android:paddingVertical="8dp"
            android:paddingHorizontal="16dp"
            android:textCursorDrawable="@null" />

        <TextView
            android:id="@+id/contact_message_error"
            style="@style/SpanThree"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:textColor="@color/destructive"
            android:textStyle="bold" />

    </LinearLayout>

    <androidx.appcompat.widget.AppCompatButton
        android:id="@+id/contact_button"
        style="@style/SpanOne"
        android:layout_width="200dp"
        android:layout_gravity="center"
        android:layout_height="wrap_content"
        android:background="@drawable/bg_gradient_btn"
        android:text="@string/btn_contact" />

    <TextView
        android:id="@+id/contact_view_recent_messages"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="32dp"
        android:gravity="center"
        android:clickable="true"
        android:focusable="true"
        android:text="@string/contact_view_messages"
        style="@style/SpanThree" />

</LinearLayout>