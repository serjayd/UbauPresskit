<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true"
    tools:context=".fragments.SubscriptionFragment">

    <LinearLayout
        android:id="@+id/main"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <LinearLayout
            android:id="@+id/subscription_header"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginBottom="32dp">

            <TextView
                android:id="@+id/subscription_title"
                style="@style/HeadingOne"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/subscription_title"
                android:layout_marginBottom="8dp" />

            <TextView
                android:id="@+id/subscription_subtitle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                style="@style/BodyTwo"
                android:textColor="@color/text_primary"
                android:text="@string/subscription_subtitle" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/subscription_form_name"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginBottom="16dp">

            <TextView
                android:id="@+id/name_label"
                style="@style/SpanThree"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginBottom="6dp"
                android:text="@string/name_form_label"
                android:textStyle="bold" />

            <EditText
                android:id="@+id/name_input"
                style="@style/BodyTwo"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:autofillHints="@string/name_hint"
                android:background="@drawable/glass_card"
                android:hint="@string/name_hint"
                android:inputType="textPersonName"
                android:textColor="@color/text_primary"
                android:minHeight="48dp"
                android:paddingVertical="8dp"
                android:paddingHorizontal="16dp"
                android:textCursorDrawable="@null" />

            <TextView
                android:id="@+id/name_error"
                style="@style/SpanThree"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:textColor="@color/destructive"
                android:textStyle="bold" />

        </LinearLayout>

        <LinearLayout
            android:id="@+id/subscription_form_email"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"

            android:orientation="vertical">

            <TextView
                android:id="@+id/email_label"
                style="@style/SpanThree"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginBottom="6dp"
                android:text="@string/email_form_label"
                android:textStyle="bold" />

            <EditText
                android:id="@+id/email_input"
                style="@style/BodyTwo"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:autofillHints="@string/email_hint"
                android:background="@drawable/glass_card"
                android:hint="@string/email_hint"
                android:textColor="@color/text_primary"
                android:inputType="textEmailAddress"
                android:minHeight="48dp"
                android:paddingVertical="8dp"
                android:paddingHorizontal="16dp"
                android:textCursorDrawable="@null" />

            <TextView
                android:id="@+id/email_error"
                style="@style/SpanThree"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:textColor="@color/destructive"
                android:textStyle="bold" />

        </LinearLayout>

        <LinearLayout
            android:id="@+id/subscription_options_container"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/glass_card"
            android:orientation="vertical"
            android:padding="16dp"
            android:layout_marginBottom="16dp">

            <TextView
                android:id="@+id/subscription_options"
                style="@style/HeadingTwo"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/subscription_options" />

            <CheckBox
                android:id="@+id/subscription_option_4"
                style="@style/BodyOne"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:checked="true"
                android:text="@string/subscription_option_4" />

            <CheckBox
                android:id="@+id/subscription_option_1"
                style="@style/BodyOne"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/subscription_option_1" />

            <CheckBox
                android:id="@+id/subscription_option_3"
                style="@style/BodyOne"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/subscription_option_3" />
        </LinearLayout>

        <androidx.appcompat.widget.AppCompatButton
            android:id="@+id/subscribe_button"
            style="@style/SpanOne"
            android:layout_width="200dp"
            android:layout_gravity="center"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_gradient_btn"
            android:text="@string/btn_subscribe" />

    </LinearLayout>
</androidx.core.widget.NestedScrollView>