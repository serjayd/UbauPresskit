<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_gradient">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- HERO SECTION -->
        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="420dp">

            <!-- Background Image -->
            <ImageView
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:src="@drawable/homepage_background_img"
                android:scaleType="centerCrop" />

            <!-- Title Text Block -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_alignParentBottom="true"
                android:orientation="vertical"
                android:padding="20dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="UBAU:"
                    android:style="@style/HeadingOne" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="TECHNO THIEF"
                    android:style="@style/HeadingOne"
                    android:textColor="@color/text_white"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="EVERY SHADOW IS A SANCTUARY; EVERY NOISE IS A THREAT."
                    android:style="@style/SpanThree"
                    android:textColor="@color/text_white"
                    android:textSize="13sp"
                    android:singleLine="true"
                    android:layout_marginTop="8dp" />

            </LinearLayout>

        </RelativeLayout>
        <!-- OUT NOW ON SECTION -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingLeft="20dp"
            android:paddingRight="20dp"
            android:paddingTop="16dp"
            android:paddingBottom="16dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="OUT NOW ON"
                android:style="@style/SpanThree"
                android:textSize="18dp"
                android:textColor="@color/green_base" />

            <!-- Platform Logos -->
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginTop="8dp">

                <ImageView
                    android:layout_width="50dp"
                    android:layout_height="50dp"
                    android:src="@drawable/playstation_logo"
                    android:layout_marginRight="12dp" />

                <ImageView
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:src="@drawable/xbox_logo" />

            </LinearLayout>


        </LinearLayout>
        <!-- DESCRIPTION SECTION -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingLeft="20dp"
            android:paddingRight="20dp"
            android:paddingTop="16dp"
            android:paddingBottom="16dp">

            <!-- Game Description -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="In a world dominated by technocrats, humanity has built concrete towers to reach the heavens. Below, life is a shadow of the past. You play as a child scavenger, dodging a strict robotic curfew to find money to pay for your sick mother's insurance."
                android:style="@style/BodyTwo"
                android:textColor="@color/text_primary" />

            <!-- Divider -->
            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="@color/orange_dark"
                android:layout_marginTop="16dp"
                android:layout_marginBottom="16dp" />

            <!-- GENRE -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <TextView
                    android:layout_width="80dp"
                    android:layout_height="wrap_content"
                    android:text="GENRE"
                    android:style="@style/SpanTwo"
                    android:textColor="@color/orange_dark" />
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="•"
                    android:textColor="@color/green_base"
                    android:textSize="20sp"
                    android:layout_marginRight="6dp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Stealth Survival"
                    android:style="@style/BodyTwo"
                    android:textColor="@color/text_primary" />

            </LinearLayout>

            <!-- LENGTH -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginTop="8dp">

                <TextView
                    android:layout_width="80dp"
                    android:layout_height="wrap_content"
                    android:text="LENGTH"
                    android:style="@style/SpanTwo"
                    android:textColor="@color/orange_dark" />
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="•"
                    android:textColor="@color/green_base"
                    android:textSize="20sp"
                    android:layout_marginRight="6dp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="6 hrs"
                    android:style="@style/BodyTwo"
                    android:textColor="@color/text_primary" />

            </LinearLayout>

            <!-- AGE -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginTop="8dp">

                <TextView
                    android:layout_width="80dp"
                    android:layout_height="wrap_content"
                    android:text="AGE"
                    android:style="@style/SpanTwo"
                    android:textColor="@color/orange_dark" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="PEGI 16+"
                    android:style="@style/BodyTwo"
                    android:textColor="@color/text_primary" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="•"
                    android:textColor="@color/green_base"
                    android:textSize="20sp"
                    android:layout_marginLeft="6dp"
                    android:layout_marginRight="6dp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="ESRB T"
                    android:style="@style/BodyTwo"
                    android:textColor="@color/text_primary" />


            </LinearLayout>


            <!-- REVIEWS SECTION -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:paddingBottom="16dp"
                android:paddingTop="16dp"

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:background="@drawable/glass_card"
                    android:padding="16dp">

                    <!-- Review 1 -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="★★★★★"
                        android:textColor="@color/orange_base"
                        android:textSize="14sp" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="&quot;A stunning atmospheric experience.&quot;"
                        android:style="@style/BodyTwo"
                        android:textSize="16sp"
                        android:layout_marginTop="6dp" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="— GAMESPOT"
                        android:style="@style/SpanThree"
                        android:layout_marginTop="6dp" />

                    <!-- Divider -->
                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:background="@color/orange_dark"
                        android:layout_marginTop="12dp"
                        android:layout_marginBottom="12dp" />

                    <!-- Review 2 -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="★★★★★"
                        android:textColor="@color/orange_base"
                        android:textSize="14sp" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="&quot;Hauntingly beautiful world design.&quot;"
                        android:style="@style/BodyTwo"
                        android:textSize="16sp"
                        android:layout_marginTop="6dp" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="— IGN"
                        android:style="@style/SpanThree"
                        android:layout_marginTop="6dp" />

                </LinearLayout>



            </LinearLayout>
            <!-- BUY NOW SECTION -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/glass_card"
                android:padding="20dp"
                android:layout_marginLeft="20dp"
                android:layout_marginRight="20dp"
                android:layout_marginBottom="16dp">

                <!-- Available Now -->
                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_gravity="center"
                    android:layout_marginBottom="12dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="•"
                        android:textColor="@color/green_base"
                        android:textSize="20sp"
                        android:layout_marginRight="6dp" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="AVAILABLE NOW"
                        android:style="@style/SpanTwo"
                        android:textColor="@color/text_white"
                        android:textStyle="bold" />

                </LinearLayout>

                <!-- Buy Now Button -->
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="BUY NOW  |  £15.99"
                    android:background="@drawable/bg_gradient_btn"
                    android:textColor="@color/bg_primary"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:gravity="center"
                    android:padding="14dp" />

            </LinearLayout>

            </LinearLayout>


        </LinearLayout>


    </LinearLayout>


</ScrollView>