<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true"
    tools:context=".fragments.GoodiesFragment">

    <LinearLayout
        android:id="@+id/main"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">
        <!-- Heading -->
        <LinearLayout
            android:id="@+id/subscription_header"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginBottom="16dp">

            <TextView
                android:id="@+id/subscription_title"
                style="@style/HeadingOne"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/goodies_title"
                android:layout_marginBottom="8dp" />

            <TextView
                android:id="@+id/subscription_subtitle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/goodies_subtitle"
                style="@style/SpanTwo"
                />

        </LinearLayout>

        <!-- Card 1 -->
        <LinearLayout
            android:id="@+id/goodies_card_1_container"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/glass_card"
            android:orientation="horizontal"
            android:padding="16dp"
            android:layout_marginBottom="16dp">

            <ImageView
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:contentDescription="@string/link_x"
                android:src="@drawable/lock_icon"
                android:layout_gravity="center"
                android:layout_marginEnd="16dp"/>
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="center"
                android:layout_marginBottom="4dp">
                <TextView
                    android:id="@+id/goodies_card_title_1"
                    style="@style/HeadingTwo"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/goodies_card_title_1"
                    />
                <TextView
                    android:id="@+id/subscription_desc_1"
                    style="@style/BodyOne"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/goodies_card_desc_1" />
            </LinearLayout>
        </LinearLayout>

        <!-- Card 2 -->
        <LinearLayout
            android:id="@+id/goodies_card_2_container"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/glass_card"
            android:orientation="horizontal"
            android:padding="16dp"
            android:layout_marginBottom="16dp">

            <ImageView
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:contentDescription="@string/link_x"
                android:src="@drawable/lock_icon"
                android:layout_gravity="center"
                android:layout_marginEnd="16dp"/>
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="center"
                android:layout_marginBottom="4dp">
                <TextView
                    android:id="@+id/goodies_card_title_2"
                    style="@style/HeadingTwo"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/goodies_card_title_2"
                    />
                <TextView
                    android:id="@+id/subscription_desc_2"
                    style="@style/BodyOne"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/goodies_card_desc_2" />
            </LinearLayout>
        </LinearLayout>

        <!-- Card 3 -->
        <LinearLayout
            android:id="@+id/goodies_card_3_container"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/glass_card"
            android:orientation="horizontal"
            android:padding="16dp"
            android:layout_marginBottom="16dp">

            <ImageView
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:contentDescription="@string/link_x"
                android:src="@drawable/lock_icon"
                android:layout_gravity="center"
                android:layout_marginEnd="16dp"/>
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="center"
                android:layout_marginBottom="4dp">
                <TextView
                    android:id="@+id/goodies_card_title_3"
                    style="@style/HeadingTwo"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/goodies_card_title_3"
                    />
                <TextView
                    android:id="@+id/subscription_desc_3"
                    style="@style/BodyOne"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/goodies_card_desc_3" />
            </LinearLayout>
        </LinearLayout>

        <!-- Card 4 -->
        <LinearLayout
            android:id="@+id/goodies_card_4_container"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/glass_card"
            android:orientation="horizontal"
            android:padding="16dp"
            android:layout_marginBottom="16dp">

            <ImageView
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:contentDescription="@string/link_x"
                android:src="@drawable/lock_icon"
                android:layout_gravity="center"
                android:layout_marginEnd="16dp"/>
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="center"
                android:layout_marginBottom="4dp">
                <TextView
                    android:id="@+id/goodies_card_title_4"
                    style="@style/HeadingTwo"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/goodies_card_title_4"
                    />
                <TextView
                    android:id="@+id/subscription_desc_4"
                    style="@style/BodyOne"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/goodies_card_desc_4" />
            </LinearLayout>
        </LinearLayout>

        <!-- Submit Button -->
        <androidx.appcompat.widget.AppCompatButton
            android:id="@+id/goodies_button_subscribe"
            style="@style/SpanOne"
            android:layout_width="200dp"
            android:layout_gravity="center"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_gradient_btn"
            android:text="@string/btn_unlock" />
    </LinearLayout>
</androidx.core.widget.NestedScrollView>